    "@types/node": "^24.2.0",
    "chalk": "^4.1.2",
    "chokidar": "^4.0.3",
    "emoji-strip": "^1.0.1",
    "ink": "6.4.0",
    "ink-link": "^5.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "qrcode-terminal": "^0.12.0",
    "react": "19.1.0",
    "react-devtools-core": "^6.1.5",
    "terminal-image": "^3.1.1",
    "timeago.js": "^4.0.2",
    "zod": "^4.0.15",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/chokidar": "^2.1.7",
    "@types/emoji-strip": "^1.0.2",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "~19.1.0",
    "prettier": "^3.6.2"
