{
  "name": "cli",
  "module": "src/cli.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun src/cli.tsx",
    "dev": "bun --watch src/cli.tsx",
    "build": "bun build --compile --outfile=subs src/cli.tsx",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@subs/contracts": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "@ts-rest/core": "^3.52.1",
